{
  "manifest_version": 3,
  "name": "JRA Extension",
  "version": "0.1.0",
  "description": "JRA競馬サイトの拡張機能",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.jra.go.jp/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.jra.go.jp/*"
      ],
      "js": ["src/content/index.ts"]
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "JRA Extension"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
